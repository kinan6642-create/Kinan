{
  "name": "cashier-pos",
  "version": "1.0.0",
  "description": "نظام كاشير احترافي - محل الساندويشات",
  "main": "main.js",
  "author": "Mohamad Rajab Hidan",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist-win": "electron-builder --win nsis --ia32 --x64 --publish never"
  },
  "dependencies": {
    "better-sqlite3": "^8.7.0"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mrhidan.cashierpos",
    "productName": "نظام الكاشير",
    "icon": "icon.ico",
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "index.html", "icon.ico", "package.json", "node_modules/**/*"],
    "asarUnpack": ["node_modules/better-sqlite3/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["ia32", "x64"] }],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "نظام الكاشير",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "artifactName": "تثبيت-نظام-الكاشير-Setup-${arch}.exe"
    }
  }
}
